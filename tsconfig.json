{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "types": ["chrome", "bun"],
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": ["src", "scripts", "oxlint.config.ts"]
}
