{
  "name": "threads-country-badge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run scripts/build.ts",
    "changepacks": "changepacks",
    "changepacks:check": "changepacks check",
    "changepacks:update": "changepacks update --yes && bun run manifest:sync",
    "dev": "bun run scripts/build.ts --watch",
    "dev:chrome": "bun run scripts/open-chrome.ts",
    "manifest:sync": "bun run scripts/sync-manifest-version.ts",
    "manifest:check": "bun run scripts/check-manifest-version.ts",
    "package": "bun run scripts/package.ts",
    "prepare": "husky",
    "test": "bun test",
    "verify:live": "bun run build && bun run scripts/live-threads-inspect.ts",
    "lint": "bunx oxlint .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@changepacks/cli": "^0.2.28",
    "@playwright/test": "^1.59.1",
    "@types/bun": "^1.3.13",
    "@types/chrome": "^0.1.40",
    "eslint-plugin-devup": "^2.0.19",
    "flag-icons": "^7.5.0",
    "husky": "^9.1.7",
    "oxlint": "^1.62.0",
    "typescript": "^6.0.3"
  }
}
